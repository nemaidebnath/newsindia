# Core WordPress (Ignore if installing via Composer or using WP as a submodule)
# ----------------------------------------------------------------------------
# Remove the hashes below if you want to ignore core WordPress files entirely
# /wp-admin/
# /wp-includes/
# /wp-*.php
# /index.php
# /xmlrpc.php

# WordPress Configuration and Environment
# ----------------------------------------------------------------------------
wp-config.php
wp-config-sample.php
.env
.env.*
!.env.example

# Content and Uploads (Never commit user uploads or backups)
# ----------------------------------------------------------------------------
wp-content/uploads/
wp-content/blogs.dir/
wp-content/upgrade/
wp-content/backup-*
wp-content/backups/
wp-content/advanced-cache.php
wp-content/wp-cache-config.php
wp-content/cache/
wp-content/managewp/

# Plugins and Themes
# ----------------------------------------------------------------------------
# Un-comment the lines below if you manage plugins/themes via Composer
# wp-content/plugins/*
# wp-content/themes/*
# !wp-content/themes/your-custom-theme-name/

# Build Tools and Dependencies
# ----------------------------------------------------------------------------
node_modules/
bower_components/
vendor/
.npm/
.yarn/
.pnpm-store/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
.stylelintcache

# Server and System Files
# ----------------------------------------------------------------------------
.htaccess
nginx.conf
*.log
*.sql
*.sqlite
*.zip
*.tar.gz

# OS and IDE Files
# ----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?